    "commander": "^11.0.0",
    "dotenv": "^16.0.3",
    "fluent-ffmpeg": "^2.1.2",
    "livekit-server-sdk": "^2.15.0",
    "node-fetch": "^2.7.0",
    "winston": "^3.8.2",
    "ws": "^8.20.0",
    "ytpl": "^2.3.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/jest": "^29.0.0",
