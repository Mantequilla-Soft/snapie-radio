# LiveKit Configuration
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Bot Configuration
BOT_USERNAME=radio-bot
BOT_PASSWORD=secure-password

# Logging
LOG_LEVEL=info

# Web UI
PORT=3000

# YouTube cookies (required on VPS — YouTube blocks data-center IPs without auth)
# Export from your browser using "Get cookies.txt LOCALLY" extension while logged in to YouTube
# then upload the file to your server and set the path here.
# YOUTUBE_COOKIES_FILE=/home/user/snapie-radio/cookies.txt

# Node Environment
NODE_ENV=production