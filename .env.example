# Hive Hangouts middleware URL (provides auth + LiveKit tokens)
HANGOUTS_API_URL=https://api.hangouts.snapie.io

# LiveKit server URL (passed to the browser for direct WebRTC connection)
LIVEKIT_URL=wss://livekit.3speak.tv

# Server port
PORT=3000

# YouTube cookies (optional — helps avoid bot-detection on some IPs)
# Export from your browser using the "Get cookies.txt LOCALLY" extension while
# logged in to YouTube, upload to your server, and set the path here.
# YOUTUBE_COOKIES_FILE=/home/user/snapie-radio/cookies.txt

# Node Environment
NODE_ENV=production